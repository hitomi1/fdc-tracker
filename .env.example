# Copy this file to .env.local and fill in your Supabase project values.
# .env.local is gitignored (matched by *.local), so your keys stay out of git.
#
# Find these in your Supabase dashboard: Project Settings → API.
# The anon key is a publishable key and is safe to expose in the frontend;
# row-level security (supabase/schema.sql) is what actually protects user data.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
